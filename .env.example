# ========================================
# RUTASEGURA - Environment Variables
# ========================================
# Copy this file as ".env" in the project root
# Restart "npm run dev" after saving
#
# BACKEND (.NET Core API)
# ========================================

# ASP.NET Core Configuration
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://0.0.0.0:5000

# Database (SQLite for development, SQL Server for production)
ConnectionStrings__DefaultConnection=Data Source=rutasegura.db

# JWT Configuration (change in production)
Jwt__Issuer=RutaSegura.API
Jwt__Audience=RutaSegura.Client
Jwt__Key=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# Redis Cache (optional, for caching)
Redis__ConnectionString=redis://localhost:6379

# Frontend URL
FRONTEND_URL=http://localhost:5173

# ========================================
# FRONTEND (React + Vite)
# ========================================

# Backend API URL
VITE_API_URL=http://localhost:5000

# Google Maps API Key
# 1) Google Cloud Console: https://console.cloud.google.com/
# 2) APIs & Services → Enable APIs → "Maps JavaScript API"
# 3) Credentials → Create API Key
# 4) (Recommended) Restrict to: localhost:5173, your production domain
VITE_GOOGLE_MAPS_API_KEY=

# ========================================
# RENDER.COM - Production Environment
# ========================================
# Add these securely in Render dashboard (not in .env)
# REDIS_CONNECTION_STRING=redis://default:password@host:port:14083
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key

