# ========================================
# RUTASEGURA - Environment Variables
# ========================================
# Copy this file as ".env" in the project root
# Restart "npm run dev" after saving
#
# BACKEND (.NET Core API)
# ========================================

# ASP.NET Core Configuration
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://0.0.0.0:5000

# Database (SQLite for development, SQL Server for production)
ConnectionStrings__DefaultConnection=Data Source=rutasegura.db

# JWT Configuration (change in production)
Jwt__Issuer=RutaSegura.API
Jwt__Audience=RutaSegura.Client
Jwt__Key=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# Redis (sesiones JWT + caché). Local: docker compose up -d
Redis__ConnectionString=localhost:6379

# Redis Cloud / Redis Labs (Render): host:puerto + contraseña aparte, o todo en una línea:
# Redis__ConnectionString=redis-14083.c98.us-east-1-4.ec2.cloud.redislabs.com:14083
# Redis__Password=TU_PASSWORD_DE_REDIS_CLOUD
# (la app añade ssl=True automáticamente para *.redislabs.com)

# Frontend URL
FRONTEND_URL=http://localhost:5173

# ========================================
# FRONTEND (React + Vite)
# ========================================

# Backend API URL
VITE_API_URL=http://localhost:5000

# Google Maps: habilita Maps JavaScript API, Geocoding API, Places API y Directions API
# Restricción recomendada en desarrollo: «Ninguna» (o clave aparte sin restricción para el backend).
# Geocode/Directions en Buscar Ruta pasan por /api/external/* (servidor); la clave debe poder usarse desde .NET.
# Referrers HTTP solo para el mapa JS: localhost:5000/*, localhost:5173/*, 127.0.0.1:5000/*
# Pon la clave REAL solo en .env (ese archivo no se sube a Git). Aquí déjala vacía:
VITE_GOOGLE_MAPS_API_KEY=
# Opcional en producción (Render): misma clave o una dedicada al servidor
# GOOGLE_MAPS_API_KEY=

# Firebase Cloud Messaging (alertas push admin → app móvil / topic)
# FIREBASE_SERVER_KEY=tu_server_key_legacy
# FCM_TOPIC=rutasegura-alertas

# WeatherAPI (backend — clima en Mapa y Rutas). https://www.weatherapi.com/
# Opcional: sin clave usa modo demo.
WEATHERAPI_API_KEY=

# ========================================
# RENDER.COM - Production Environment
# ========================================
# Add these securely in Render dashboard (not in .env)
# REDIS_CONNECTION_STRING=redis://default:password@host:port:14083
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key

